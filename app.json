{
  "expo": {
    "name": "Inner Fire Breath",
    "slug": "inner-fire-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#000000",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "experiments": {
      "baseUrl": "/inner-fire-breathing-simulator"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.samezenbody.innerfirebreath"
    },
    "android": {
      "package": "com.samezenbody.innerfirebreath",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#000000"
      },
      "permissions": [
        "WAKE_LOCK",
        "INTERNET",
        "MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "single",
      "themeColor": "#000000",
      "display": "standalone",
      "statusBarStyle": "black-translucent",
      "backgroundColor": "#000000"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ]
    ],
    "owner": "same-zen-bodys-organization",
    "extra": {
      "eas": {
        "projectId": "e3c731b7-4505-4ee4-8e16-e0f80270081d"
      }
    }
  }
}
